{
  // The capture window is centered on the moment a band crosses the
  // crosshair line (perfect press = 0 ms).
  "timing": {
    "captureWindowMs": 250,
    "windowCenterOffsetMs": 0
  },

  // Speed = period between objects in ms (franticness). Names appear in the
  // lobby selector and the CSV filename.
  "speeds": {
    "slow": 1500,
    "fast": 1000,
    "extreme": 500
  },
  "defaultSpeed": "fast",

  // How long before its crossing a band fades in near the top of the screen
  // (its whole trajectory is prespawned). Must exceed the longest reaction
  // time + half window. Rendering only.
  "fall": {
    "fadeLeadMs": 2500
  },

  // Difficulty = the set of reaction times (ms from the band's reveal to
  // the end of the capture window). Values at/below ~300ms are effectively
  // impossible and probe finger-selection errors; every difficulty includes
  // at least one impossible timing (150ms).
  "difficulties": {
    "easy":   { "reactionTimesMs": [150, 500, 650, 800, 1000] },
    "medium": { "reactionTimesMs": [150, 225, 450, 600, 800] },
    "hard":   { "reactionTimesMs": [150, 225, 300, 400, 500] }
  },

  "run": {
    "targetTrialCount": 100, // fixed across speeds; rounds up to the nearest counterbalanced multiple
    "trialCountBounds": [80, 140]
  },

  // correct/wrong apply inside the window; earlyLate to mistimed presses;
  // noPress to each object that crosses the line untouched; excessPress to every
  // press beyond the per-cycle limit (spamming loses points!).
  "scoring": {
    "correct": 3,
    "wrongFinger": 1,
    "earlyLate": 0,
    "noPress": -1,
    "excessPress": -1
  },

  // Physical key positions (KeyboardEvent.code), so non-QWERTY layouts still
  // use the same fingers. t/i/m/r/l = thumb, index, middle, ring, little.
  "keys": {
    "l": { "l": "KeyQ", "r": "KeyW", "m": "KeyE", "i": "KeyR", "t": "KeyV" },
    "r": { "t": "KeyN", "i": "KeyU", "m": "KeyI", "r": "KeyO", "l": "KeyP" }
  },

  "visuals": {
    "fingerColors": {
      "t": "#f4b942",
      "i": "#e4572e",
      "m": "#2ab7a9",
      "r": "#5c6bc0",
      "l": "#ab5cc0"
    },
    "handShapes": { "l": "diamond", "r": "circle" },
    "popDurationMs": 380,
    "scoreFloatDurationMs": 900,
    "glowIntensity": 0.3
  },

  "modes": {
    "threeFingerSet": ["i", "m", "r"],
    "fourFingerSet": ["i", "m", "r", "l"], // non-thumb four (Q-W-E-R / U-I-O-P)
    "singleHandThumbKey": "Space", // thumb key in one-handed modes (shown as '_')
    "mobile": { "fingers": 4, "maxChord": 2 }
  },

  // Synthesized cues: a low pulse at each crossing and per-outcome score
  // cues (no background track). Set masterVolume to 0 to disable.
  "audio": {
    "masterVolume": 0.5
  }
}
